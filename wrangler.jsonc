{
  "name": "x402-web-scraper",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "src/index.ts",
  "browser": {
    "binding": "BROWSER"
  },
  "vars": {
